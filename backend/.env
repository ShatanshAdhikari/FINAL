# ─────────────────────────────────────────────
#  GetFit Backend — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Security ──────────────────────────────────
# Secret key used to sign JWT tokens.
# Generate a strong one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=81f969671ba0f77c0057e8e6800d4f29af274bcd9f7b698d9591364b2181e578

# JWT signing algorithm (do not change unless you know what you're doing)
ALGORITHM=HS256

# How long a login token stays valid (in minutes). Default = 1440 = 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./getfit.db
# PostgreSQL example (uncomment and fill in for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/getfit

# ── Nutritionix Food Search API ───────────────
# Powers the food search in the Calorie Tracker.
# Get FREE keys at: https://www.nutritionix.com/business/api
# Leave blank to use mock/fallback data instead.
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# ── CORS / Frontend URL ───────────────────────
# The URL your React frontend runs on.
# Used by FastAPI to allow cross-origin requests.
FRONTEND_URL=http://localhost:5173
