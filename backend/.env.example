# ─────────────────────────────────────────────
#  GetFit Backend — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# NEVER commit the real .env file — it is in .gitignore.

# ── Security ──────────────────────────────────
# Secret key used to sign JWT tokens. REQUIRED.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-generated-secret-key-here

# JWT signing algorithm (do not change)
ALGORITHM=HS256

# How long a login token stays valid (in minutes). Default = 1440 = 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./getfit.db
# PostgreSQL example (uncomment and fill in for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/getfit

# ── Food Search APIs ──────────────────────────
# Option 1 (default): USDA FoodData Central — free, no signup needed for DEMO_KEY.
# Get a free personal key for higher limits at https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=DEMO_KEY

# Option 2: Nutritionix (premium, more food names / NLP search).
# Get FREE keys at: https://www.nutritionix.com/business/api
# If both ID and KEY are set, Nutritionix is used instead of USDA.
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# ── CORS / Frontend URL ───────────────────────
# The URL your React frontend runs on.
FRONTEND_URL=http://localhost:5173

# ── Email ─────────────────────────────────────
# Backend priority: SendGrid → Resend → Gmail SMTP → dev console log.
# Leave all of these blank in dev and verification links are printed to the
# console instead of being emailed.

# Option 1 (recommended): SendGrid HTTP API. Works on hosts that block SMTP
# (Render does) and needs only a single verified sender — no domain required.
# Verify a sender at Settings → Sender Authentication → Verify a Single Sender,
# then create an API key with the Mail Send scope only.
SENDGRID_API_KEY=
SENDGRID_FROM=GetFit <your-verified-sender@example.com>

# Option 2: Resend HTTP API. Also HTTPS-only, but the default onboarding
# sender only delivers to your own Resend signup address — emailing arbitrary
# users requires verifying a domain you own.
RESEND_API_KEY=
RESEND_FROM=GetFit <onboarding@resend.dev>

# Option 3: Gmail SMTP — local dev only. SMTP_PASS must be a 16-character
# Gmail App Password (2-Step Verification required), not the account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GetFit <your-gmail@gmail.com>
