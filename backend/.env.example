# GetFit Backend Environment Configuration
# Copy this file to .env and fill in your values

# JWT Secret Key — REQUIRED, no default. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-generated-secret-key-here

# Database (SQLite by default)
DATABASE_URL=sqlite:///./getfit.db

# Nutritionix API (for food search) — get free keys at https://www.nutritionix.com/business/api
# Leave empty to use mock data
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=
