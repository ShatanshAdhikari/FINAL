# ─────────────────────────────────────────────
#  GetFit Backend — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# NEVER commit the real .env file — it is in .gitignore.

# ── Security ──────────────────────────────────
# Secret key used to sign JWT tokens. REQUIRED.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-generated-secret-key-here

# JWT signing algorithm (do not change)
ALGORITHM=HS256

# How long a login token stays valid (in minutes). Default = 1440 = 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./getfit.db
# PostgreSQL example (uncomment and fill in for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/getfit

# ── Food Search APIs ──────────────────────────
# Option 1 (default): USDA FoodData Central — free, no signup needed for DEMO_KEY.
# Get a free personal key for higher limits at https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=DEMO_KEY

# Option 2: Nutritionix (premium, more food names / NLP search).
# Get FREE keys at: https://www.nutritionix.com/business/api
# If both ID and KEY are set, Nutritionix is used instead of USDA.
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# ── CORS / Frontend URL ───────────────────────
# The URL your React frontend runs on.
FRONTEND_URL=http://localhost:5173
